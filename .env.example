# === Polymarket ===
POLYMARKET_PRIVATE_KEY=your_private_key_here
POLYMARKET_API_KEY=your_api_key
POLYMARKET_API_SECRET=your_api_secret
POLYMARKET_PASSPHRASE=your_passphrase

# === Weather APIs ===
OPENWEATHERMAP_API_KEY=your_owm_key
NOAA_USER_AGENT=poly-autobet/1.0

# === AI Multi-Provider (只需填入你有的，至少一個) ===
AI_PROVIDER=minimax           # gpt | deepseek | minimax | kimi | qwen | glm | gemini
AI_MODEL=                     # 留空 = 使用 provider 預設模型

OPENAI_API_KEY=               # GPT-4o       → api.openai.com
DEEPSEEK_API_KEY=             # DeepSeek-V3  → api.deepseek.com
MINIMAX_API_KEY=              # MiniMax-M2.5 → api.minimax.io
KIMI_API_KEY=                 # Kimi 2.5     → api.moonshot.ai
QWEN_API_KEY=                 # Qwen 3.5     → dashscope.aliyuncs.com
GLM_API_KEY=                  # GLM-4        → open.bigmodel.cn
GEMINI_API_KEY=               # Gemini 2.5   → generativelanguage.googleapis.com

# === Redis & DB ===
REDIS_URL=redis://localhost:6379
DATABASE_URL=sqlite+aiosqlite:///./data/polybet.db

# === Notifications ===
TELEGRAM_BOT_TOKEN=your_telegram_token
TELEGRAM_CHAT_ID=your_chat_id

# === Trading ===
TRADING_MODE=paper
MAX_DAILY_EXPOSURE=500
MAX_SINGLE_BET=50
NODE_ROLE=brain
