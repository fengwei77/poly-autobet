# === Polymarket ===
# Required for live trading
POLYMARKET_PRIVATE_KEY=your_private_key_here
POLYMARKET_API_KEY=your_api_key
POLYMARKET_API_SECRET=your_api_secret
POLYMARKET_PASSPHRASE=your_passphrase

# === Weather APIs ===
# Get free API key from https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=your_owm_key
# User agent for NOAA requests
NOAA_USER_AGENT=poly-autobet/1.0

# === AI Multi-Provider ===
# Choose one provider: gpt | deepseek | minimax | kimi | qwen | glm | gemini
AI_PROVIDER=minimax
# Leave empty to use provider's default model
AI_MODEL=

# === AI API Keys (fill at least one) ===
# OpenAI - https://platform.openai.com/api-keys
OPENAI_API_KEY=
# DeepSeek - https://platform.deepseek.com/
DEEPSEEK_API_KEY=
# MiniMax - https://platform.minimax.io/
MINIMAX_API_KEY=
# Kimi/Moonshot - https://platform.moonshot.ai/
KIMI_API_KEY=
# Qwen/Alibaba - https://dashscope.console.aliyun.com/
QWEN_API_KEY=
# GLM/Zhipu - https://open.bigmodel.cn/
GLM_API_KEY=
# Gemini/Google AI - https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# === Redis & Database ===
# Redis connection URL
REDIS_URL=redis://localhost:6379
# SQLite database path
DATABASE_URL=sqlite+aiosqlite:///./data/polybet.db

# === Telegram Notifications ===
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_token
# Get from @userinfobot on Telegram
TELEGRAM_CHAT_ID=your_chat_id
# Secret token for webhook verification (optional)
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret
# Base URL for Telegram webhook (optional, e.g., https://your-domain.com)
TELEGRAM_WEBHOOK_BASE_URL=

# === Trading Configuration ===
# Mode: monitor | paper | live | backtest
TRADING_MODE=paper
# Brain node analyzes and executes, executor only executes
NODE_ROLE=brain
# Delegate execution to another node via Redis
DELEGATE_EXECUTION=false

# === Risk Management ===
# Maximum daily exposure in USD
MAX_DAILY_EXPOSURE=500
# Maximum single bet in USD
MAX_SINGLE_BET=50
# Minimum single bet in USD
MIN_SINGLE_BET=2
# Minimum edge required to trade (5% = 0.05)
MIN_EDGE=0.05
# Minimum AI confidence threshold (0-100)
CONFIDENCE_THRESHOLD=70
# Kelly fraction for position sizing (0.25 = conservative)
KELLY_FRACTION=0.25
# Maximum open positions
MAX_POSITIONS=20
# Maximum positions per city
MAX_PER_CITY=3

# === Strategy ===
# Trading strategy: auto | semi-auto
TRADING_STRATEGY=auto
# Consecutive losses before pause
MAX_CONSEQUENT_LOSS_LIMIT=10
# Maximum capital utilization (80% = 0.8)
MAX_CAPITAL_UTILIZATION=0.8

# === Scanning ===
# Scan interval in minutes
SCAN_INTERVAL_MINUTES=15
# Deep analysis interval in minutes
DEEP_ANALYSIS_INTERVAL_MINUTES=60
# Auto-exit hours before market resolution
AUTO_EXIT_HOURS_BEFORE_RESOLUTION=1

# === Stop Loss ===
# Stop loss percentage (20% = 0.20)
STOP_LOSS_PCT=0.20
# Daily stop loss in USD
DAILY_STOP_LOSS=100
# Weekly stop loss in USD
WEEKLY_STOP_LOSS=300
# Pause duration after consecutive losses (in hours)
PAUSE_DURATION_HOURS=6
# Number of consecutive losses before pause
CONSECUTIVE_LOSS_PAUSE=5

# === Scalping Strategy ===
# Take profit percentage for scalping (15% = 0.15)
SCALPING_TAKE_PROFIT_PCT=0.15
# Stop loss percentage for scalping (10% = 0.10)
SCALPING_STOP_LOSS_PCT=0.10

# === Live Trading ===
# Actual bankroll for live trading (used for risk calculations)
LIVE_BANKROLL=1000

# === AI Analysis ===
# Edge threshold for AI analysis in paper mode (1% = 0.01)
AI_TRIGGER_THRESHOLD_PAPER=0.01
# Edge threshold for AI analysis in live mode (3% = 0.03)
AI_TRIGGER_THRESHOLD_LIVE=0.03
